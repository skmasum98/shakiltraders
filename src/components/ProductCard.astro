---
// File: src/components/ProductCard.astro
export interface Product {
  id: number;
  name: string;
  category: string;
  description: string;
  image: string;
  packaging: string;
  stock: string;
  features: string[];
  minimumOrder: number;
}

const { product, categories, view = 'grid' } = Astro.props;
---

{view === 'grid' ? (
  <!-- Grid View Card -->
  <div 
    class="product-card group bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2" 
    data-category={product.category} 
    data-name={product.name.toLowerCase()}
  >
    <div class="relative overflow-hidden">
      <img 
        src={product.image} 
        alt={product.name} 
        class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-500"
        loading="lazy"
      />
      <div class="absolute top-4 right-4">
        <span class={`${categories[product.category].color} text-white px-3 py-1 rounded-full text-sm font-semibold`}>
          {categories[product.category].name}
        </span>
      </div>
      <div class="absolute inset-0 bg-black opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
    </div>
    
    <div class="p-6">
      <h3 class="text-xl font-bold text-gray-800 mb-2 group-hover:text-blue-700 transition-colors duration-300">
        {product.name}
      </h3>
      <p class="text-gray-600 mb-4 line-clamp-2">
        {product.description}
      </p>
      
      <!-- Features -->
      <div class="mb-4">
        <div class="flex flex-wrap gap-1 mb-3">
          {product.features.slice(0, 2).map((feature: string) => (
            <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs font-medium">
              {feature}
            </span>
          ))}
          {product.features.length > 2 && (
            <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs font-medium">
              +{product.features.length - 2} more
            </span>
          )}
        </div>
      </div>
      
      <!-- Product Details -->
      <div class="space-y-2 mb-4">
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-600 font-medium">Packaging:</span>
          <span class="text-sm font-semibold text-blue-800">{product.packaging}</span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-600 font-medium">Stock:</span>
          <span class={`text-sm font-semibold ${
            product.stock === 'In Stock' ? 'text-green-600' : 
            product.stock === 'Limited Stock' ? 'text-amber-600' : 'text-red-600'
          }`}>
            {product.stock}
          </span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-600 font-medium">Min. Order:</span>
          <span class="text-sm font-semibold text-gray-800">{product.minimumOrder} case</span>
        </div>
      </div>
      
      <!-- CTA Button -->
      <div class="border-t pt-4">
        <a 
          href={`/contact?product=${encodeURIComponent(product.name)}`}
          class="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors duration-300 transform hover:scale-105 block text-center group/btn"
        >
          Request Quote
          <i class="fas fa-arrow-right ml-2 transform group-hover/btn:translate-x-1 transition-transform duration-300"></i>
        </a>
      </div>
    </div>
  </div>
) : (
  <!-- List View Card -->
  <div 
    class="product-card group bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300" 
    data-category={product.category} 
    data-name={product.name.toLowerCase()}
  >
    <div class="flex flex-col md:flex-row">
      <div class="md:w-1/3 relative">
        <img 
          src={product.image} 
          alt={product.name} 
          class="w-full h-64 md:h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
        <div class="absolute top-4 right-4">
          <span class={`${categories[product.category].color} text-white px-3 py-1 rounded-full text-sm font-semibold`}>
            {categories[product.category].name}
          </span>
        </div>
      </div>
      
      <div class="md:w-2/3 p-6">
        <div class="flex flex-col h-full">
          <div class="flex-1">
            <h3 class="text-2xl font-bold text-gray-800 mb-3 group-hover:text-blue-700 transition-colors duration-300">
              {product.name}
            </h3>
            <p class="text-gray-600 mb-4">
              {product.description}
            </p>
            
            <!-- Features -->
            <div class="mb-4">
              <div class="flex flex-wrap gap-2">
                {product.features.map((feature: string) => (
                  <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium">
                    {feature}
                  </span>
                ))}
              </div>
            </div>
            
            <!-- Product Details -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
              <div class="text-center">
                <div class="text-sm text-gray-600 font-medium mb-1">Packaging</div>
                <div class="text-lg font-semibold text-blue-800">{product.packaging}</div>
              </div>
              <div class="text-center">
                <div class="text-sm text-gray-600 font-medium mb-1">Stock Status</div>
                <div class={`text-lg font-semibold ${
                  product.stock === 'In Stock' ? 'text-green-600' : 
                  product.stock === 'Limited Stock' ? 'text-amber-600' : 'text-red-600'
                }`}>
                  {product.stock}
                </div>
              </div>
              <div class="text-center">
                <div class="text-sm text-gray-600 font-medium mb-1">Minimum Order</div>
                <div class="text-lg font-semibold text-gray-800">{product.minimumOrder} case</div>
              </div>
            </div>
          </div>
          
          <!-- CTA Button -->
          <div class="border-t pt-4">
            <a 
              href={`/contact?product=${encodeURIComponent(product.name)}`}
              class="w-full bg-blue-600 text-white py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors duration-300 transform hover:scale-105 block text-center group/btn"
            >
              Request Quote for {product.name}
              <i class="fas fa-arrow-right ml-2 transform group-hover/btn:translate-x-1 transition-transform duration-300"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
)}