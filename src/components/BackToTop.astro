---
// src/components/BackToTop.astro
---
<!-- All styling is moved to the 'class' attribute, making it safe for Tailwind v4 -->
<button 
  id="back-to-top" 
  title="Go to top" 
  aria-label="Go to top"
  class="
    fixed bottom-6 right-6 z-50 
    bg-blue-600 text-white rounded-full w-14 h-14 
    flex items-center justify-center cursor-pointer 
    shadow-xl transition-all duration-300
    opacity-0 invisible translate-y-5
    hover:bg-blue-700 hover:shadow-2xl hover:scale-105
  "
>
  <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 19V5M5 12l7-7 7 7"/>
  </svg>
</button>

<script>
  if (typeof window !== 'undefined') {
    document.addEventListener('DOMContentLoaded', () => {
      const backToTopButton = document.getElementById('back-to-top');

      if (backToTopButton) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 400) {
            // Toggle classes to show the button
            backToTopButton.classList.remove('opacity-0', 'invisible', 'translate-y-5');
            backToTopButton.classList.add('opacity-100', 'visible', 'translate-y-0');
          } else {
            // Toggle classes to hide the button
            backToTopButton.classList.remove('opacity-100', 'visible', 'translate-y-0');
            backToTopButton.classList.add('opacity-0', 'invisible', 'translate-y-5');
          }
        });

        backToTopButton.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    });
  }
</script>

<!-- The <style> block is now removed entirely! -->