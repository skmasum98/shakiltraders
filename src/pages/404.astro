---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found | Kahn Wholesale Ltd">
  <div class="flex min-h-[calc(100vh-160px)] flex-col items-center justify-center bg-white py-16 text-center">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
      
      <!-- Error Code & Icon -->
      <p class="text-6xl font-extrabold text-blue-600 sm:text-7xl">
        404
      </p>
      <div class="mt-4 text-7xl">
        🤷‍♂️
      </div>

      <!-- Main Message -->
      <h1 class="mt-8 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Oops! Page Not Found
      </h1>

      <p class="mt-4 text-lg text-slate-600">
        We couldn't find the page you were looking for. It might have been moved, deleted, or you might have mistyped the address.
      </p>

      <!-- Navigation/CTA -->
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a 
          href="/" 
          class="inline-flex items-center justify-center rounded-lg bg-blue-600 px-8 py-3 font-semibold text-white shadow-md transition-all duration-300 hover:bg-blue-700 hover:-translate-y-0.5"
        >
          Go to Homepage
        </a>
        <a 
          href="/contact" 
          class="inline-flex items-center justify-center rounded-lg border-2 border-slate-300 px-8 py-3 font-semibold text-slate-700 transition-all duration-300 hover:border-blue-500 hover:text-blue-600"
        >
          Contact Support
        </a>
      </div>
      
    </div>
  </div>
</Layout>