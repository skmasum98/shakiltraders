---
import Layout from "../layouts/Layout.astro";
import { products, categories } from "../data/products";

// Define types for better safety
type CategoryKey = keyof typeof categories;

const uniqueCategories = Object.keys(categories) as CategoryKey[];
---

<Layout title="Our Products | Vital Supply Ltd" description="Explore premium wholesale household goods, beverages, personal care, and more from Vital Supply Ltd.">
  <section class="bg-gray-50 py-16">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl font-bold text-center text-gray-800 mb-6">
        Our Product Range
      </h1>
      <p class="text-center text-gray-600 mb-12 max-w-3xl mx-auto">
        At <strong>Vital Supply Ltd</strong>, we specialize in a diverse selection of wholesale consumer goods — from personal care and beverages to confectionery, household essentials, and wellness products.
      </p>

      <!-- Category Filter -->
      <div class="flex flex-wrap justify-center gap-3 mb-10">
        <button class="filter-btn px-5 py-2 bg-gray-200 text-gray-800 rounded-full hover:bg-gray-300 active-category" data-category="all">
          All
        </button>
        {uniqueCategories.map((key) => (
          <button
            class={`filter-btn px-5 py-2 text-white rounded-full hover:opacity-90 ${categories[key].color}`}
            data-category={key}
          >
            {categories[key].name}
          </button>
        ))}
      </div>

      <!-- Product Grid -->
      <div id="productGrid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((product) => {
          const categoryKey = product.category as CategoryKey;
          const cat = categories[categoryKey];

          return (
            <div
              class="product-card bg-white shadow-md rounded-lg overflow-hidden hover:shadow-xl transition-shadow duration-300"
              data-category={product.category}
            >
              <img src={product.image} alt={product.name} class="w-full h-56 object-cover" />
              <div class="p-6">
                <div class={`inline-block px-3 py-1 text-sm text-white rounded-full ${cat.color}`}>
                  {cat.name}
                </div>
                <h3 class="text-xl font-semibold mt-3 text-gray-800">{product.name}</h3>
                <p class="text-gray-600 text-sm mt-2">{product.description}</p>

                <ul class="mt-3 space-y-1 text-sm text-gray-700">
                  <li><strong>Packaging:</strong> {product.packaging}</li>
                  <li><strong>Stock:</strong> {product.stock}</li>
                  <li><strong>Min Order:</strong> {product.minimumOrder}</li>
                </ul>

                <ul class="mt-3 text-xs text-gray-600 list-disc list-inside">
                  {product.features.map((f) => <li>{f}</li>)}
                </ul>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <script>
    // Client-side filtering
    const buttons = document.querySelectorAll(".filter-btn");
    const cards = document.querySelectorAll(".product-card");

    buttons.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const el = e.currentTarget as HTMLElement;
        const category = el.dataset.category;

        // Update active button
        buttons.forEach((b) => b.classList.remove("active-category"));
        el.classList.add("active-category");

        cards.forEach((card) => {
          const cardEl = card as HTMLElement;
          const match = category === "all" || cardEl.dataset.category === category;
          cardEl.style.display = match ? "block" : "none";
        });
      });
    });
  </script>

  
</Layout>
