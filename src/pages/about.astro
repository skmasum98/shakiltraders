---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us | Shakil Traders Limited">
  <!-- Hero Section -->
  <section class="bg-slate-900 py-20 text-white">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Our Mission</h1>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto leading-relaxed">
        Connecting London's finest establishments with the freshest produce and premium seafood, 
        sourced responsibly and delivered with absolute reliability.
      </p>
    </div>
  </section>

  <!-- Company Overview -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl font-bold text-slate-900 mb-6">A Trusted Name in Wholesale</h2>
          <div class="space-y-4 text-gray-600 leading-relaxed text-lg">
            <p>
              Founded and headquartered in the heart of London at **101 Whitechapel High Street**, 
              Shakil Traders Limited has established itself as a cornerstone of the local food supply chain. 
              We specialize in the bulk distribution of high-quality fruits, vegetables, and seafood.
            </p>
            <p>
              Our strategic location allows us to serve the diverse culinary landscape of London, 
              from independent grocers to high-end restaurants. We understand that in the food industry, 
              **freshness is not negotiable.**
            </p>
            <p>
              As a registered private limited company (No. 13318529), we operate with full transparency, 
              adhering to the highest standards of food safety and trade regulations.
            </p>
          </div>
        </div>
        <div class="relative">
          <img 
            src="https://images.unsplash.com/photo-1574321024216-65239e248037?auto=format&fit=crop&q=80&w=800" 
            alt="London Wholesale Market" 
            class="rounded-2xl shadow-2xl"
          />
          <div class="absolute -bottom-6 -left-6 bg-green-600 text-white p-8 rounded-xl hidden lg:block">
            <p class="text-4xl font-bold italic">Reliable.</p>
            <p class="text-lg opacity-90">Fresh. Everyday.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Expertise (SIC Codes focus) -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-slate-900">Our Core Specialisms</h2>
        <p class="text-gray-500 mt-2">Specialized wholesale services across two primary sectors</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Expertise 1 -->
        <div class="bg-white p-10 rounded-2xl shadow-sm border border-slate-100">
          <div class="text-green-600 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4">Fruit & Vegetables (SIC 46310)</h3>
          <p class="text-gray-600">
            From seasonal staples to exotic imports, we manage a robust supply chain that ensures 
            produce moves from the farm to your kitchen in peak condition. We prioritize seasonal 
            availability and competitive pricing for our bulk partners.
          </p>
        </div>

        <!-- Expertise 2 -->
        <div class="bg-white p-10 rounded-2xl shadow-sm border border-slate-100">
          <div class="text-blue-600 mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4">Seafood & Shellfish (SIC 46380)</h3>
          <p class="text-gray-600">
            Our seafood division focuses on the wholesale of fresh-water fish, crustaceans, and 
            molluscs. We work with trusted fisheries to ensure that our seafood is handled 
            with the temperature-controlled precision required for food safety.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Legal/Trust Section -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="bg-slate-900 rounded-3xl p-8 md:p-12 text-white flex flex-col md:flex-row items-center gap-8">
        <div class="flex-1">
          <h2 class="text-2xl font-bold mb-4">Corporate Transparency</h2>
          <p class="text-slate-400 mb-6 italic">SHAKIL TRADERS LIMITED is a registered entity in England and Wales.</p>
          <ul class="space-y-2 text-sm">
            <li><span class="text-slate-500">Company Number:</span> 13318529</li>
            <li><span class="text-slate-500">Registered Office:</span> 101 Whitechapel High Street, London, E1 7RA</li>
            <li><span class="text-slate-500">Status:</span> Active Private Limited Company</li>
          </ul>
        </div>
        <div class="w-full md:w-auto">
          <a href="#contact" class="inline-block bg-white text-slate-900 px-8 py-4 rounded-xl font-bold hover:bg-slate-100 transition w-full text-center">
            Partner With Us
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>