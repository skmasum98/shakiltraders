---
import Layout from '../layouts/Layout.astro';

const categories = [
  {
    title: "Fresh Vegetables",
    description: "Daily essentials from local farms and international growers.",
    items: ["Leafy Greens", "Root Vegetables", "Brassicas", "Salad Crops", "Alliums (Onions/Garlic)"],
    image: "https://cdn.mos.cms.futurecdn.net/v2/t:0,l:200,cw:1200,ch:1200,q:80,w:1200/ttRcAKkAuabG9JWzvahtiA.jpg"
  },
  {
    title: "Seasonal Fruits",
    description: "Picked at peak ripeness for maximum flavor and shelf life.",
    items: ["Citrus Fruits", "Stone Fruits", "Berries", "Apples & Pears", "Melons"],
    image: "https://images.unsplash.com/photo-1619566636858-adf3ef46400b?auto=format&fit=crop&q=80&w=800"
  },
  {
    title: "Exotic & Specialty",
    description: "Hard-to-find ingredients for specialized cuisines.",
    items: ["Mangoes & Papayas", "Fresh Chilies", "Asian Greens", "Exotic Roots", "Specialty Herbs"],
    image: "https://images.unsplash.com/photo-1523348837708-15d4a09cfac2?auto=format&fit=crop&q=80&w=800"
  }
];
---

<Layout title="Wholesale Fruit & Vegetables | Shakil Traders Limited">
  <!-- Hero Section -->
  <section class="bg-green-50 py-16 md:py-24 border-b border-green-100">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <span class="text-green-600 font-bold tracking-widest uppercase text-sm">SIC Code 46310</span>
      <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 mt-4 mb-6">
        Wholesale Fruit & <span class="text-green-600">Vegetables</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        Providing London's food sector with premium, farm-fresh produce. We manage the logistics so you get the best of the harvest every morning.
      </p>
    </div>
  </section>

  <!-- Product Categories Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-10">
        {categories.map((cat) => (
          <div class="flex flex-col group">
            <div class="overflow-hidden rounded-2xl mb-6 shadow-lg h-64">
              <img 
                src={cat.image} 
                alt={cat.title} 
                class="w-full h-full object-cover transition duration-500 group-hover:scale-110"
              />
            </div>
            <h2 class="text-2xl font-bold text-slate-900 mb-3">{cat.title}</h2>
            <p class="text-gray-600 mb-6">{cat.description}</p>
            <ul class="space-y-2 mt-auto">
              {cat.items.map((item) => (
                <li class="flex items-center text-slate-700 font-medium">
                  <svg class="h-5 w-5 text-green-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Wholesale Service Highlights -->
  <section class="py-20 bg-slate-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-col lg:flex-row items-center gap-16">
        <div class="lg:w-1/2">
          <h2 class="text-3xl font-bold mb-8">Why Source from Shakil Traders?</h2>
          
          <div class="space-y-8">
            <div class="flex gap-4">
              <div class="bg-white p-3 rounded-lg shadow-sm h-fit">
                <span class="text-2xl">🚛</span>
              </div>
              <div>
                <h4 class="font-bold text-lg">Next-Day London Delivery</h4>
                <p class="text-gray-600">Order by 10 PM for early morning delivery across Greater London.</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="bg-white p-3 rounded-lg shadow-sm h-fit">
                <span class="text-2xl">🌍</span>
              </div>
              <div>
                <h4 class="font-bold text-lg">Global & Local Sourcing</h4>
                <p class="text-gray-600">Combining seasonal British produce with year-round imports from trusted global partners.</p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="bg-white p-3 rounded-lg shadow-sm h-fit">
                <span class="text-2xl">📦</span>
              </div>
              <div>
                <h4 class="font-bold text-lg">Flexible Bulk Packaging</h4>
                <p class="text-gray-600">From crates and sacks to pre-packed options to suit your business needs.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="lg:w-1/2 bg-green-600 rounded-3xl p-12 text-white relative">
          <h3 class="text-3xl font-bold mb-6">Get Today's Price List</h3>
          <p class="mb-8 text-green-100 text-lg">
            Market prices fluctuate daily. Contact our sales desk to get our current wholesale rates and seasonal availability.
          </p>
          <ul class="space-y-4 mb-10">
            <li class="flex items-center gap-3">
              <span class="bg-green-500 p-1 rounded-full text-xs">✓</span> Competitive Volume Discounts
            </li>
            <li class="flex items-center gap-3">
              <span class="bg-green-500 p-1 rounded-full text-xs">✓</span> Credit Accounts Available (Subject to Status)
            </li>
          </ul>
          <a href="#contact" class="inline-block w-full text-center bg-white text-green-700 font-bold py-4 rounded-xl hover:bg-green-50 transition">
            Request Quote
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>