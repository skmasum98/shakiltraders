---
import Layout from '../layouts/Layout.astro';

const seafoodCategories = [
  {
    title: "Fresh Water & Sea Fish",
    description: "Premium selection of whole and filleted fish, sourced daily.",
    items: ["Atlantic Salmon", "Sea Bass & Sea Bream", "Cod & Haddock", "Tilapia & Rohu", "Mackerel & Sardines"],
    image: "https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?auto=format&fit=crop&q=80&w=800"
  },
  {
    title: "Crustaceans",
    description: "High-quality shellfish for restaurants and specialized retailers.",
    items: ["King & Tiger Prawns", "Native & Canadian Lobster", "Brown & Blue Crabs", "Langoustines", "Shrimps"],
    image: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQpIREU7WzRB2X3oJ765XFTse5AA9863sbcAxnygCRO2eqiMhBa1rk9zzxUKM0Tn3VTYazihbF3YbBnDEcXJBpuecJ7XXuTgGZ3qRml7w&s=10"
  },
  {
    title: "Molluscs",
    description: "Freshly harvested bivalves and cephalopods.",
    items: ["Mussels & Clams", "King Scallops", "Oysters", "Squid & Cuttlefish", "Octopus"],
    image: "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRJDTu20Kv8QjoNCq2gwrOcjwWOdrqkF1Jw1xespLy_uxlOtUx7n-Bs_sontcb0C8LxilYGV6lw8muanCRqbAo0MxnS7oYt5SnNm6RFDA&s=10"
  }
];
---

<Layout title="Wholesale Seafood | Fish & Shellfish Suppliers | Shakil Traders Limited">
  <!-- Hero Section -->
  <section class="bg-slate-900 py-16 md:py-24 relative overflow-hidden text-white">
    <!-- Abstract background pattern -->
    <div class="absolute inset-0 opacity-10">
        <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
            <path d="M0 50 Q 25 40 50 50 T 100 50 V 100 H 0 Z" fill="white"></path>
        </svg>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 text-center relative z-10">
      <span class="text-blue-400 font-bold tracking-widest uppercase text-sm">SIC Code 46380</span>
      <h1 class="text-4xl md:text-6xl font-extrabold mt-4 mb-6 uppercase tracking-tight">
        Wholesale <span class="text-blue-400">Seafood</span> & Fish
      </h1>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto font-light">
        Distributing premium fresh-water fish, crustaceans, and molluscs across London. We prioritize cold-chain integrity and sustainable sourcing.
      </p>
    </div>
  </section>

  <!-- Product Categories Grid -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-8">
        {seafoodCategories.map((cat) => (
          <div class="bg-white rounded-3xl shadow-xl shadow-slate-200/50 overflow-hidden group">
            <div class="h-56 overflow-hidden">
              <img 
                src={cat.image} 
                alt={cat.title} 
                class="w-full h-full object-cover transition duration-700 group-hover:scale-110"
              />
            </div>
            <div class="p-8">
              <h2 class="text-2xl font-bold text-slate-900 mb-4 flex items-center gap-2">
                <span class="w-2 h-8 bg-blue-600 rounded-full block"></span>
                {cat.title}
              </h2>
              <p class="text-slate-500 mb-6 leading-relaxed">{cat.description}</p>
              <div class="flex flex-wrap gap-2">
                {cat.items.map((item) => (
                  <span class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-xs font-bold border border-blue-100">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quality Control Section -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-8 leading-tight">
            Strict Temperature Control & <br/><span class="text-blue-600">Cold Chain Management</span>
          </h2>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="bg-blue-600 p-2 rounded-lg text-white">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-slate-900">Food Safety Standards</h4>
                <p class="text-slate-600">Fully compliant with UK Health & Safety regulations for the storage and distribution of fish products.</p>
              </div>
            </div>
            
            <div class="flex items-start gap-4">
              <div class="bg-blue-600 p-2 rounded-lg text-white">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-slate-900">Rapid Turnaround</h4>
                <p class="text-slate-600">Our Whitechapel hub ensures seafood moves from wholesale markets to your premises in the shortest possible window.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="order-1 lg:order-2">
            <div class="relative">
                <img 
                  src="https://img.freepik.com/free-photo/close-up-fresh-fish-with-gills-ice_23-2148295243.jpg" 
                  alt="Fresh fish on ice" 
                  class="rounded-3xl shadow-2xl z-10 relative"
                />
                <div class="absolute -top-4 -right-4 w-64 h-64 bg-blue-100 rounded-full mix-blend-multiply filter blur-3xl opacity-70"></div>
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 bg-slate-900">
    <div class="max-w-7xl mx-auto px-4">
        <div class="border border-slate-700 rounded-3xl p-8 md:p-16 text-center">
            <h3 class="text-3xl md:text-4xl font-bold text-white mb-6">Partner with London's Seafood Experts</h3>
            <p class="text-slate-400 mb-10 max-w-xl mx-auto text-lg">
                Become a wholesale partner today and gain access to seasonal catches and premium imports.
            </p>
            <div class="flex flex-col md:flex-row gap-4 justify-center">
                <a href="tel:+440000000000" class="bg-white text-slate-900 px-8 py-4 rounded-xl font-bold hover:bg-blue-50 transition">
                    Call Sales Desk
                </a>
                <a href="/contact" class="bg-blue-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-blue-700 transition">
                    Request Price List
                </a>
            </div>
        </div>
    </div>
  </section>
</Layout>