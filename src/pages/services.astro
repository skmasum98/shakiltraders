---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Our Services | Vital Supply Ltd"
  description="Explore Vital Supply Ltd's wholesale services — including product sourcing, logistics, private labeling, and tailored supply chain solutions across the UK."
>

  <!-- Hero Section -->
  <section class="bg-linear-to-r from-blue-900 to-blue-600 text-white py-24 text-center">
    <div class="max-w-5xl mx-auto px-6">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Our Services</h1>
      <p class="text-lg text-blue-100">
        Delivering reliable wholesale supply solutions across the UK — from sourcing to distribution.
      </p>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="text-lg text-gray-700 max-w-3xl mx-auto">
        At <strong>Vital Supply Ltd</strong>, we go beyond supplying products — we provide complete
        wholesale solutions designed to support retailers, supermarkets, and businesses of all sizes.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-12 text-gray-800">What We Offer</h2>

      <div class="grid md:grid-cols-3 gap-10">
        <!-- Service 1 -->
        <div class="bg-white p-8 rounded-2xl shadow hover:shadow-lg transition">
          <i class="fa-solid fa-boxes-stacked text-blue-700 text-4xl mb-4"></i>
          <h3 class="text-xl font-semibold mb-3">Wholesale Distribution</h3>
          <p class="text-gray-600">
            We supply a wide range of household goods, personal care, beverages, confectionery, and cleaning products to UK retailers and wholesalers.
          </p>
        </div>

        <!-- Service 2 -->
        <div class="bg-white p-8 rounded-2xl shadow hover:shadow-lg transition">
          <i class="fa-solid fa-handshake text-blue-700 text-4xl mb-4"></i>
          <h3 class="text-xl font-semibold mb-3">B2B Partnership Solutions</h3>
          <p class="text-gray-600">
            We collaborate with businesses to create tailored wholesale solutions that meet their supply chain and distribution needs effectively.
          </p>
        </div>

        <!-- Service 3 -->
        <div class="bg-white p-8 rounded-2xl shadow hover:shadow-lg transition">
          <i class="fa-solid fa-truck-fast text-blue-700 text-4xl mb-4"></i>
          <h3 class="text-xl font-semibold mb-3">Efficient Logistics</h3>
          <p class="text-gray-600">
            With strong logistics and warehousing capabilities, we ensure on-time delivery and smooth distribution across the UK.
          </p>
        </div>

        <!-- Service 4 -->
        <div class="bg-white p-8 rounded-2xl shadow hover:shadow-lg transition">
          <i class="fa-solid fa-cubes text-blue-700 text-4xl mb-4"></i>
          <h3 class="text-xl font-semibold mb-3">Product Sourcing</h3>
          <p class="text-gray-600">
            Need specific products? Our sourcing experts connect with trusted global suppliers to fulfill your inventory demands efficiently.
          </p>
        </div>

        <!-- Service 5 -->
        <div class="bg-white p-8 rounded-2xl shadow hover:shadow-lg transition">
          <i class="fa-solid fa-industry text-blue-700 text-4xl mb-4"></i>
          <h3 class="text-xl font-semibold mb-3">Private Label Solutions</h3>
          <p class="text-gray-600">
            We assist businesses in creating private label products under their own brand — from concept to packaging and supply.
          </p>
        </div>

        <!-- Service 6 -->
        <div class="bg-white p-8 rounded-2xl shadow hover:shadow-lg transition">
          <i class="fa-solid fa-headset text-blue-700 text-4xl mb-4"></i>
          <h3 class="text-xl font-semibold mb-3">Customer Support & Consulting</h3>
          <p class="text-gray-600">
            Our dedicated support team ensures seamless order handling and provides expert advice for your wholesale needs.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Benefits -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-12 text-gray-800">Why Businesses Choose Us</h2>
      <div class="grid md:grid-cols-4 gap-8">
        <div class="p-6 bg-gray-50 rounded-2xl shadow hover:shadow-lg transition">
          <i class="fa-solid fa-tag text-blue-700 text-3xl mb-3"></i>
          <h4 class="font-semibold text-lg mb-2">Competitive Pricing</h4>
          <p class="text-gray-600 text-sm">We offer wholesale prices that help maximize your business profitability.</p>
        </div>
        <div class="p-6 bg-gray-50 rounded-2xl shadow hover:shadow-lg transition">
          <i class="fa-solid fa-box-open text-blue-700 text-3xl mb-3"></i>
          <h4 class="font-semibold text-lg mb-2">Reliable Supply</h4>
          <p class="text-gray-600 text-sm">Consistent stock availability ensures your shelves are always full.</p>
        </div>
        <div class="p-6 bg-gray-50 rounded-2xl shadow hover:shadow-lg transition">
          <i class="fa-solid fa-chart-line text-blue-700 text-3xl mb-3"></i>
          <h4 class="font-semibold text-lg mb-2">Scalable Solutions</h4>
          <p class="text-gray-600 text-sm">We adapt to your business growth with flexible and scalable supply options.</p>
        </div>
        <div class="p-6 bg-gray-50 rounded-2xl shadow hover:shadow-lg transition">
          <i class="fa-solid fa-user-shield text-blue-700 text-3xl mb-3"></i>
          <h4 class="font-semibold text-lg mb-2">Trusted Partnerships</h4>
          <p class="text-gray-600 text-sm">Our clients trust us for integrity, transparency, and long-term collaboration.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-blue-900 text-white text-center">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-6">Ready to Partner with Vital Supply Ltd?</h2>
      <p class="text-blue-100 mb-8">
        We’re here to power your retail and wholesale growth with dependable supply and service excellence.
      </p>
      <a
        href="/contact"
        class="bg-white text-blue-800 font-semibold px-6 py-3 rounded-full shadow hover:bg-gray-100 transition"
      >
        Contact Us
      </a>
    </div>
  </section>
</Layout>
