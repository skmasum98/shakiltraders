---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Wholesale Inquiries | Shakil Traders Limited">
  <!-- Hero Header -->
  <section class="bg-slate-900 py-20 text-white">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Connect With Our Sales Desk</h1>
      <p class="text-slate-400 max-w-2xl mx-auto text-lg">
        Whether you're looking for a new primary supplier or a one-off bulk order, our team is ready to assist your business.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-3 gap-12">
        
        <!-- Left Column: Contact Info -->
        <div class="lg:col-span-1 space-y-10">
          <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-green-600 mb-4">Registered Office</h3>
            <p class="text-xl font-bold text-slate-900">Shakil Traders Limited</p>
            <p class="text-slate-600 mt-2">
              101 Whitechapel High Street<br />
              London, England, E1 7RA
            </p>
          </div>

          <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-green-600 mb-4">Direct Contact</h3>
            <div class="space-y-3">
              <a href="tel:+442012345678" class="flex items-center gap-3 text-slate-700 hover:text-green-600 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <span class="font-semibold">+447927702536</span>
              </a>
              <a href="mailto:info@shakiltraders.com" class="flex items-center gap-3 text-slate-700 hover:text-green-600 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="font-semibold">info@shakiltradersltd.com</span>
              </a>
            </div>
          </div>

          <div>
            <h3 class="text-sm font-bold uppercase tracking-widest text-green-600 mb-4">Trading Hours</h3>
            <ul class="text-slate-600 space-y-2">
              <li class="flex justify-between border-b border-slate-100 pb-2">
                <span>Monday - Saturday</span>
                <span class="font-bold text-slate-900 text-sm">09:00 - 17:00</span>
              </li>
              <li class="flex justify-between">
                <span>Sunday</span>
                <span class="text-slate-400 text-sm uppercase">Closed</span>
              </li>
            </ul>
            <p class="mt-4 text-xs text-slate-400">* Wholesale hours align with morning market fresh deliveries.</p>
          </div>
        </div>

        <!-- Right Column: Inquiry Form -->
        <div class="lg:col-span-2">
          <div class="bg-slate-50 p-8 md:p-12 rounded-3xl border border-slate-100 shadow-sm">
            <h2 class="text-2xl font-bold text-slate-900 mb-6">Wholesale Inquiry Form</h2>
            
            <form action="#" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="col-span-1">
                <label class="block text-sm font-bold text-slate-700 mb-2">Your Name</label>
                <input type="text" name="name" required class="w-full bg-white border border-slate-200 rounded-xl p-4 focus:ring-2 focus:ring-green-500 focus:border-transparent outline-none transition" placeholder="John Doe" />
              </div>
              
              <div class="col-span-1">
                <label class="block text-sm font-bold text-slate-700 mb-2">Business Name</label>
                <input type="text" name="company" required class="w-full bg-white border border-slate-200 rounded-xl p-4 focus:ring-2 focus:ring-green-500 outline-none transition" placeholder="Restaurant or Shop Name" />
              </div>

              <div class="col-span-1">
                <label class="block text-sm font-bold text-slate-700 mb-2">Email Address</label>
                <input type="email" name="email" required class="w-full bg-white border border-slate-200 rounded-xl p-4 focus:ring-2 focus:ring-green-500 outline-none transition" placeholder="email@business.com" />
              </div>

              <div class="col-span-1">
                <label class="block text-sm font-bold text-slate-700 mb-2">Inquiry Type</label>
                <select name="type" class="w-full bg-white border border-slate-200 rounded-xl p-4 focus:ring-2 focus:ring-green-500 outline-none transition appearance-none">
                  <option>Wholesale Fruit & Veg</option>
                  <option>Wholesale Seafood</option>
                  <option>General Partnership</option>
                </select>
              </div>

              <div class="col-span-full">
                <label class="block text-sm font-bold text-slate-700 mb-2">How can we help?</label>
                <textarea name="message" rows="5" required class="w-full bg-white border border-slate-200 rounded-xl p-4 focus:ring-2 focus:ring-green-500 outline-none transition" placeholder="List specific products or delivery requirements..."></textarea>
              </div>

              <div class="col-span-full">
                <button type="submit" class="w-full bg-slate-900 text-white font-bold py-5 rounded-xl hover:bg-slate-800 transition-all shadow-lg hover:shadow-xl active:scale-[0.98]">
                  Submit Wholesale Request
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Simple Map Placeholder (Google Maps Embed) -->
  <section class="h-112.5 w-full grayscale contrast-125 hover:grayscale-0 transition-all duration-700">
    <iframe 
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2482.91617260934!2d-0.0743644233792476!3d51.51475737181467!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4876034b07166e41%3A0xc39115d91c28c894!2s101%20Whitechapel%20High%20St%2C%20London%20E1%207RA!5e0!3m2!1sen!2suk!4v1700000000000!5m2!1sen!2suk" 
      width="100%" 
      height="100%" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      referrerpolicy="no-referrer-when-downgrade">
    </iframe>
  </section>
</Layout>